# 文档生成
site/
_build/

# mmd 图表
*.mmd

# 项目备份
*.backup

# 发布产物（各子包独立构建时不互相干扰）
packages/*/dist/
packages/*/*.egg-info/

# 内置默认配置应被跟踪，不忽略
!packages/fp-core/src/fp_core/config.default.json

# Agent 本地记忆
.fp/

# 构建生成的版本文件（由 setuptools-scm 写入）
**/_version.py

# WebUI 静态资源 — favicon 不被 *.png 规则屏蔽
!packages/fp-webui/src/fp_webui/static/favicon.png
